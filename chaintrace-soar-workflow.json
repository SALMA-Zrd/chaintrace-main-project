    {
      "parameters": {
        "jsCode": "const certData = $input.first().json;\n// On va rechercher les données d'origine nettoyées dans ton premier nœud 'Normalise'\nconst prevData = $('Normalise').first().json;\n\nreturn [{\n  json: {\n    ...prevData, // On injecte supplierID, productID, quantityGap, riskFlag, etc.\n    certIsValid: certData.isValid === true,\n    certReason: certData.reason || 'Aucune raison',\n    certStatus: certData.cert?.Status || 'UNKNOWN',\n    certScore: parseFloat(certData.cert?.QualityScore) || 0,\n    certExpiry: certData.cert?.ExpiryDate || ''\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
