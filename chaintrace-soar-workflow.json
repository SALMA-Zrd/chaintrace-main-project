      "parameters": {
        "jsCode": "// Récupération directe du body simplifié envoyé par l'API\nconst inputData = $input.first().json;\nconst body = inputData.body || inputData;\n\nreturn [{ json: {\n  supplierID: body.supplierID || 'unknown',\n  productID: body.productID || 'unknown',\n  qualityScore: 0,\n  qualityStatus: body.qualityStatus || 'UNKNOWN',\n  riskFlag: body.severity === 'CRITICAL',\n  quantityGap: 0,\n  conditionStatus: 'OK',\n  timestamp: body.timestamp || new Date().toISOString(),\n  source: 'ChainTrace-SOAR-Direct'\n}}];"
      },
      "type": "n8n-nodes-base.code",
