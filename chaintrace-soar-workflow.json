    },
    {
      "parameters": {
        "jsCode": "const roleData = $input.first().json;\n// On va chercher les données cumulées du nœud de merge PKI précédent\nconst prevData = $('Merge PKI').first().json;\n\n// Si l'API a renvoyé une erreur (ex: 404) ou si le rôle n'existe pas, SupplierID sera absent\nconst hasRole = roleData.SupplierID !== undefined && roleData.SupplierID !== null;\n\nreturn [{\n  json: {\n    ...prevData, // On garde TOUT : produit, PKI, anomalies de base\n    roleExists: hasRole,\n    roleValue: hasRole ? roleData.Role : 'AUCUN',\n    roleActive: hasRole ? roleData.IsActive : false,\n    roleAssignedBy: hasRole ? roleData.AssignedBy : ''\n  }\n}];"
      },
