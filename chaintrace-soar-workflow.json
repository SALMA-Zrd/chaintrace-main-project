        "specifyBody": "json",
        "jsonBody": "={\n  \"attachments\": [\n    {\n      \"color\": \"{{ $json.alertColor }}\",\n      \"title\": \"{{ $json.alertEmoji }} {{ $json.alertTitle }}\",\n      \"fields\": [\n        { \"title\": \"Fournisseur\", \"value\": \"{{ $json.supplierID }}\", \"short\": true },\n        { \"title\": \"Produit\", \"value\": \"{{ $json.productID }}\", \"short\": true },\n        { \"title\": \"Sévérité\", \"value\": \"{{ $json.severity }}\", \"short\": true },\n        { \"title\": \"Score Qualité\", \"value\": \"{{ $json.qualityScore }}/10\", \"short\": true },\n        { \"title\": \"Certificat PKI\", \"value\": \"{{ $json.certIsValid ? 'VALIDE ✅' : 'INVALIDE ❌' }}\", \"short\": true },\n        { \"title\": \"Rôle RBAC\", \"value\": \"{{ $json.roleValue }} ({{ $json.roleActive ? 'Actif' : 'Inactif' }})\", \"short\": true },\n        { \"title\": \"Recommandation\", \"value\": \"{{ $json.recommendation }}\", \"short\": false },\n        { \"title\": \"Alert ID\", \"value\": \"{{ $json.alertID }}\", \"short\": true }\n      ]\n    }\n  ]\n}",
        "options": {}
