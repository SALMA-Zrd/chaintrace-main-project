    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\n// On évalue les règles NIST directement sur les données reçues\nlet severity = 'NORMAL';\n\nif (data.riskFlag === true || data.certIsValid === false || data.roleExists === false || data.roleActive === false) {\n  severity = 'CRITICAL';\n} else if (data.qualityStatus === 'FAIL' || data.quantityGap !== 0 || data.conditionStatus !== 'OK') {\n  severity = 'HIGH';\n} else if (data.qualityScore < 7) {\n  severity = 'MEDIUM';\n}\n\nconst messages = {\n  CRITICAL: {\n    emoji: '🚨',\n    color: '#FF0000',\n    title: 'ALERTE CRITIQUE — Action immédiate requise',\n    recommendation: 'Menace détectée sur l\\'infrastructure (PKI/RBAC/RiskFlag). Suspendre immédiatement les accès du fournisseur.'\n  },\n  HIGH: {\n    emoji: '⚠️',\n    color: '#FF8C00',\n    title: 'ALERTE HAUTE — Anomalie Métier Détectée',\n    recommendation: 'Écart de quantité ou défaut qualité blockchain. Bloquer le lot de produits et inspecter la cargaison.'\n  },\n  MEDIUM: {\n    emoji: '⚡',\n    color: '#FFD700',\n    title: 'ALERTE MOYENNE — Score Qualité Faible',\n    recommendation: 'Le score de qualité est inférieur au seuil recommandé. Placer le fournisseur sous surveillance.'\n  },\n  NORMAL: {\n    emoji: '✅',\n    color: '#00AA00',\n    title: 'Transaction Blockchain Validée',\n    recommendation: 'Aucune anomalie détectée. Processus nominal.'\n  }\n};\n\nconst msg = messages[severity];\n\nreturn [{\n  json: {\n    ...data,\n    severity: severity,\n    alertEmoji: msg.emoji,\n    alertColor: msg.color,\n    alertTitle: msg.title,\n    recommendation: msg.recommendation,\n    alertID: `ALERT-${Date.now()}`,\n    formattedTime: new Date(data.timestamp || Date.now()).toLocaleString('fr-FR')\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
